@inject IUiTextService T
@{
    ViewData["Title"] = T["AccessDeniedTitle"];
}

<section class="state-page">
    <div class="state-panel">
        <span class="state-code">403</span>
        <h1>@T["AccessDeniedTitle"]</h1>
        <p>@T["AccessDeniedText"]</p>
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">@T["Home"]</a>
    </div>
</section>
