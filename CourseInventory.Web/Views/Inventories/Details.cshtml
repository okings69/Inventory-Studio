@model InventoryDetailsViewModel
@inject IMarkdownService Markdown
@inject IUiTextService T
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Inventory.Title;
    var inventory = Model.Inventory;
    var fields = inventory.Fields.OrderBy(f => f.SortOrder).ToList();
    var tableFields = fields.Where(f => f.ShowInTable).ToList();
    var tags = string.Join(", ", inventory.InventoryTags.Select(t => t.Tag!.Name));
    var items = inventory.Items.OrderByDescending(i => i.UpdatedAt).ToList();
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var canLikeItems = User.Identity?.IsAuthenticated == true;
    var descriptionMarkdown = TrimDuplicateHeading(inventory.Title, inventory.DescriptionMarkdown);
}

<section class="details-shell">
    <div class="details-hero mb-4">
        <div class="details-hero-main">
            <p class="eyebrow mb-2">@inventory.Category</p>
            <h1>@inventory.Title</h1>
            <div class="details-meta">
                <span>@T["By"] @inventory.Owner?.UserName</span>
                <span>@inventory.UpdatedAt.ToLocalTime().ToString("g")</span>
                <span class="access-badge @(inventory.IsPublic ? "is-public" : "is-private")">@(inventory.IsPublic ? "Public" : "Private")</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(descriptionMarkdown))
            {
                <div class="markdown details-description">@Html.Raw(Markdown.ToHtml(descriptionMarkdown))</div>
            }
        </div>
        @if (Model.Access.CanWrite)
        {
            <a class="btn btn-primary glow-button" asp-controller="Items" asp-action="Create" asp-route-inventoryId="@inventory.Id">@T["AddItem"]</a>
        }
    </div>

    <ul class="nav details-tabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#items" type="button">@T["Items"]</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#chat" type="button">Chat</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#settings" type="button">@T["Settings"]</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#customid" type="button">@T["CustomId"]</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#fields" type="button">@T["Fields"]</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#access" type="button">@T["Access"]</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#stats" type="button">@T["Stats"]</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#export" type="button">@T["Export"]</button></li>
    </ul>

    <div class="tab-content details-tab-content">
        <section class="tab-pane fade show active" id="items">
            <div class="panel details-panel">
                @if (canLikeItems)
                {
                    @Html.AntiForgeryToken()
                }
                <div class="panel-header">
                    <div>
                        <h2>@T["Items"]</h2>
                        <p>@items.Count item(s), @tableFields.Count visible custom column(s).</p>
                    </div>
                    @if (Model.Access.CanWrite)
                    {
                        <a class="btn btn-sm btn-primary" asp-controller="Items" asp-action="Create" asp-route-inventoryId="@inventory.Id">@T["AddItem"]</a>
                    }
                </div>
                <form asp-controller="Items" asp-action="DeleteSelected" method="post" data-items-toolbar hidden>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="inventoryId" value="@inventory.Id" />
                    <div class="inventory-bulk-toolbar m-0">
                        <div class="bulk-toolbar-meta">
                            <strong data-items-selected-count>0 selected</strong>
                            <span>Select one row to edit, or several rows to delete.</span>
                        </div>
                        <button class="btn btn-outline-primary btn-sm" type="button" data-items-edit disabled>@T["Edit"]</button>
                        @if (Model.Access.CanWrite)
                        {
                            <button class="btn btn-outline-danger btn-sm" type="submit">@T["DeleteSelected"]</button>
                        }
                        <button class="btn btn-outline-secondary btn-sm" type="button" data-items-clear>@T["ClearSelection"]</button>
                    </div>
                    <div data-items-hidden-inputs></div>
                </form>
                <div class="table-responsive">
                    <table class="table app-table table-hover align-middle details-items-table" data-details-items-table>
                        <thead>
                            <tr>
                                <th class="check-col">
                                    <input class="form-check-input" type="checkbox" data-items-select-all aria-label="@T["SelectRows"]" />
                                </th>
                                <th>@T["CustomId"]</th>
                                @foreach (var field in tableFields)
                                {
                                    <th title="@field.Description">@field.Title</th>
                                }
                                <th class="text-end">@T["Likes"]</th>
                                <th>@T["Updated"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (items.Any())
                            {
                                @foreach (var item in items)
                                {
                                    <tr data-href="@Url.Action("Details", "Items", new { item.Id })" data-id="@item.Id" tabindex="0" aria-label="Edit item @item.CustomId">
                                        <td class="check-col" data-no-row-click>
                                            <input class="form-check-input" type="checkbox" data-item-select value="@item.Id" />
                                        </td>
                                        <td>
                                            <div class="table-title">@item.CustomId</div>
                                            <div class="table-subtitle">#@item.Id</div>
                                        </td>
                                        @foreach (var field in tableFields)
                                        {
                                            var value = GetFieldValue(item, field.FieldKey);
                                            var statusClass = GetStatusBadgeClass(field, value);

                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(statusClass))
                                                {
                                                    <span class="badge item-status-badge @statusClass">@FormatFieldValue(value)</span>
                                                }
                                                else
                                                {
                                                    @FormatFieldValue(value)
                                                }
                                            </td>
                                        }
                                        <td class="text-end">
                                            @{
                                                var isLikedByCurrentUser = canLikeItems && item.Likes.Any(l => l.UserId == currentUserId);
                                            }
                                            @if (canLikeItems)
                                            {
                                                <button
                                                    class="likes-pill likes-pill-button @(isLikedByCurrentUser ? "is-liked" : string.Empty)"
                                                    type="button"
                                                    title="Toggle like"
                                                    data-no-row-click
                                                    data-item-like
                                                    data-item-id="@item.Id"
                                                    data-inventory-id="@inventory.Id"
                                                    aria-pressed="@(isLikedByCurrentUser.ToString().ToLowerInvariant())">
                                                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                        <path d="M12 21.35 10.55 20C5.4 15.24 2 12.09 2 8.25 2 5.42 4.42 3 7.25 3c1.6 0 3.14.74 4.15 1.91A5.53 5.53 0 0 1 15.55 3C18.38 3 20.8 5.42 20.8 8.25c0 3.84-3.4 6.99-8.55 11.76L12 21.35Z" fill="currentColor" />
                                                    </svg>
                                                    <span data-item-like-count>@item.Likes.Count</span>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="likes-pill" title="@item.Likes.Count like(s)">
                                                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                        <path d="M12 21.35 10.55 20C5.4 15.24 2 12.09 2 8.25 2 5.42 4.42 3 7.25 3c1.6 0 3.14.74 4.15 1.91A5.53 5.53 0 0 1 15.55 3C18.38 3 20.8 5.42 20.8 8.25c0 3.84-3.4 6.99-8.55 11.76L12 21.35Z" fill="currentColor" />
                                                    </svg>
                                                    <span>@item.Likes.Count</span>
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <div class="details-updated">@item.UpdatedAt.ToLocalTime().ToString("g")</div>
                                            <div class="table-subtitle">Open to edit</div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@(tableFields.Count + 4)" class="text-center text-body-secondary py-4">
                                        No items found
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="tab-pane fade" id="chat" data-inventory-id="@inventory.Id">
            <div class="panel details-panel">
                <div class="panel-header">
                    <div><h2>Chat</h2><p>Markdown messages for this inventory.</p></div>
                </div>
                <div id="chatMessages" class="chat-box details-chat">
                    @foreach (var message in inventory.Messages.OrderBy(m => m.CreatedAt))
                    {
                        <article class="chat-message">
                            <div class="chat-avatar">@((message.Author?.UserName ?? "U").Substring(0, 1).ToUpperInvariant())</div>
                            <div class="chat-bubble">
                                <div class="chat-meta">@message.Author?.UserName <span>@message.CreatedAt.ToLocalTime().ToString("g")</span></div>
                                <div class="markdown">@Html.Raw(message.BodyHtml)</div>
                            </div>
                        </article>
                    }
                </div>
                @if (Model.Access.CanWrite)
                {
                    <form asp-controller="Discussion" asp-action="Add" method="post" id="chatForm" class="chat-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="inventoryId" value="@inventory.Id" />
                        <textarea class="form-control" name="body" rows="3" placeholder="@T["MarkdownMessage"]"></textarea>
                        <button class="btn btn-primary">@T["Send"]</button>
                    </form>
                }
            </div>
        </section>

        <section class="tab-pane fade" id="settings">
            <div class="panel details-panel">
                <div class="panel-header">
                    <div><h2>@T["Settings"]</h2><p>Autosave keeps title, description, category and access current.</p></div>
                    <span id="autosaveStatus" class="autosave-pill">@T["AllChangesSaved"]</span>
                </div>
                @if (Model.Access.CanManage)
                {
                    <form asp-action="SaveSettings" method="post" id="settingsForm" class="details-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@inventory.Id" />
                        <input type="hidden" name="RowVersion" value="@inventory.RowVersion" />
                        <div class="row g-3">
                            <div class="col-md-8"><label class="form-label">@T["Title"]</label><input class="form-control" name="Title" value="@inventory.Title" required /></div>
                            <div class="col-md-4"><label class="form-label">@T["Category"]</label><input class="form-control" name="Category" value="@inventory.Category" required /></div>
                            <div class="col-12"><label class="form-label">@T["DescriptionMarkdown"]</label><textarea class="form-control" name="DescriptionMarkdown" rows="5">@inventory.DescriptionMarkdown</textarea></div>
                            <div class="col-md-8"><label class="form-label">@T["ImageUrl"]</label><input class="form-control" name="ImageUrl" value="@inventory.ImageUrl" /></div>
                            <div class="col-md-4"><label class="form-label">@T["Tags"]</label><input class="form-control" name="Tags" value="@tags" /></div>
                            <div class="col-12"><label class="form-label">Status dropdown options</label><input class="form-control" name="StatusOptions" value="@inventory.StatusOptions" /><div class="form-text">Comma-separated values used in the item status select.</div></div>
                            <div class="col-12">
                                <div class="switch-row">
                                    <div><strong>@T["PublicWriteAccess"]</strong><div class="text-body-secondary small">@T["PublicWriteAccessHelp"]</div></div>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" name="IsPublic" value="true" checked="@inventory.IsPublic" /></div>
                                </div>
                            </div>
                            <div class="col-12"><button class="btn btn-primary">@T["Save"]</button></div>
                        </div>
                    </form>
                }
                else
                {
                    <p class="text-body-secondary p-3 mb-0">@T["ReadOnly"]</p>
                }
            </div>
        </section>

        <section class="tab-pane fade" id="customid">
            <div class="panel details-panel">
                <div class="panel-header">
                    <div><h2>@T["CustomId"]</h2><p>Build the generated ID pattern for new items.</p></div>
                    <code id="customIdPreview" class="custom-id-preview">@Model.CustomIdPreview</code>
                </div>
                @if (Model.Access.CanManage)
                {
                    <form asp-controller="CustomId" asp-action="Add" method="post" class="details-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="inventoryId" value="@inventory.Id" />
                        <div class="row g-2">
                            <div class="col-md-3"><select class="form-select" name="elementType" asp-items="Html.GetEnumSelectList<CustomIdElementType>()"></select></div>
                            <div class="col-md-3"><input class="form-control" name="fixedValue" placeholder="@T["FixedValue"]" /></div>
                            <div class="col-md-3"><input class="form-control" name="format" placeholder="@T["Format"]" /></div>
                            <div class="col-md-3"><button class="btn btn-outline-primary w-100">@T["AddElement"]</button></div>
                        </div>
                    </form>
                }
                <div class="builder-list">
                    @foreach (var element in inventory.CustomIdElements.OrderBy(e => e.SortOrder))
                    {
                        <article class="builder-row">
                            <div><strong>@element.ElementType</strong><span>@element.FixedValue @element.Format</span></div>
                            @if (Model.Access.CanManage)
                            {
                                <form asp-controller="CustomId" asp-action="Delete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@element.Id" />
                                    <input type="hidden" name="inventoryId" value="@inventory.Id" />
                                    <button class="btn btn-sm btn-outline-danger">@T["Remove"]</button>
                                </form>
                            }
                        </article>
                    }
                </div>
            </div>
        </section>

        <section class="tab-pane fade" id="fields">
            <div class="panel details-panel">
                <div class="panel-header">
                    <div><h2>@T["Fields"]</h2><p>Up to three fields per type. Visible fields become item table columns.</p></div>
                </div>
                @if (Model.Access.CanManage)
                {
                    <form asp-controller="Fields" asp-action="Add" method="post" class="details-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="inventoryId" value="@inventory.Id" />
                        <div class="row g-2">
                            <div class="col-md-3"><select class="form-select" name="fieldType" asp-items="Html.GetEnumSelectList<InventoryFieldType>()"></select></div>
                            <div class="col-md-4"><input class="form-control" name="title" placeholder="@T["FieldTitle"]" required /></div>
                            <div class="col-md-3"><input class="form-control" name="description" placeholder="Description" /></div>
                            <div class="col-md-2"><button class="btn btn-outline-primary w-100">@T["AddField"]</button></div>
                        </div>
                    </form>
                }
                <div class="field-grid">
                    @foreach (var field in fields)
                    {
                        <article class="field-card">
                            <div class="field-card-header">
                                <div>
                                    <strong>@field.Title</strong>
                                    <span>@field.FieldType / @field.FieldKey</span>
                                </div>
                                @if (Model.Access.CanManage)
                                {
                                    <form asp-controller="Fields" asp-action="Delete" method="post" class="field-delete-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@field.Id" />
                                        <input type="hidden" name="inventoryId" value="@inventory.Id" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                    </form>
                                }
                            </div>
                            <p>@field.Description</p>
                        </article>
                    }
                </div>
            </div>
        </section>

        <section class="tab-pane fade" id="access">
            <div class="panel details-panel">
                <div class="panel-header">
                    <div><h2>@T["Access"]</h2><p>Public/private status and users with write access.</p></div>
                    <span class="access-badge @(inventory.IsPublic ? "is-public" : "is-private")">@(inventory.IsPublic ? "Public" : "Private")</span>
                </div>
                @if (Model.Access.CanManage)
                {
                    <form asp-controller="Access" asp-action="Grant" method="post" class="details-form access-grant-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="inventoryId" value="@inventory.Id" />
                        <input type="hidden" name="userId" data-access-user-id />
                        <div class="access-autocomplete">
                            <input class="form-control" data-access-search placeholder="@T["UserIdAutocomplete"]" autocomplete="off" />
                            <div class="tag-suggestions" data-access-suggestions hidden></div>
                        </div>
                        <button class="btn btn-outline-primary">@T["Grant"]</button>
                    </form>
                }
                <div class="builder-list">
                    @foreach (var row in inventory.Accesses.OrderBy(a => a.User!.UserName))
                    {
                        <article class="builder-row">
                            <div><strong>@row.User?.UserName</strong><span>@row.User?.Email</span></div>
                            @if (Model.Access.CanManage)
                            {
                                <form asp-controller="Access" asp-action="Revoke" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="inventoryId" value="@inventory.Id" />
                                    <input type="hidden" name="userId" value="@row.UserId" />
                                    <button class="btn btn-sm btn-outline-danger">@T["Remove"]</button>
                                </form>
                            }
                        </article>
                    }
                </div>
            </div>
        </section>

        <section class="tab-pane fade" id="stats">
            <div class="panel details-panel">
                <div class="panel-header"><div><h2>@T["Stats"]</h2><p>Items, likes, numeric averages and frequent values.</p></div></div>
                <div class="stats-strip details-stats">
                    <article class="metric stat-card"><span>@T["ItemsCount"]</span><strong>@Model.Stats?.ItemCount</strong></article>
                    <article class="metric stat-card"><span>@T["Likes"]</span><strong>@Model.Stats?.TotalLikes</strong></article>
                </div>
                <div class="row g-3 p-3">
                    <div class="col-lg-6">
                        <h3 class="h6">@T["NumericFields"]</h3>
                        <table class="table app-table compact-table">
                            <thead><tr><th>@T["Field"]</th><th>@T["Min"]</th><th>@T["Max"]</th><th>@T["Average"]</th></tr></thead>
                            <tbody>
                            @foreach (var stat in Model.Stats!.NumberStats)
                            {
                                <tr><td>@stat.Key</td><td>@stat.Value.Min</td><td>@stat.Value.Max</td><td>@stat.Value.Average</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                    <div class="col-lg-6">
                        <h3 class="h6">Frequent values</h3>
                        <div class="builder-list">
                            @foreach (var stat in Model.Stats!.FrequentTextValues)
                            {
                                <article class="builder-row"><div><strong>@stat.Key</strong><span>@string.Join(", ", stat.Value.Select(v => $"{v.Value} ({v.Count})"))</span></div></article>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="tab-pane fade" id="export">
            <div class="panel details-panel">
                <div class="panel-header"><div><h2>@T["Export"]</h2><p>Download item data for reporting or migration.</p></div></div>
                <div class="p-3"><a class="btn btn-outline-primary" asp-controller="Export" asp-action="Csv" asp-route-inventoryId="@inventory.Id">@T["ExportCsv"]</a></div>
            </div>
        </section>
    </div>
</section>

@section Scripts {
    <script src="~/js/inventory-details.js" asp-append-version="true"></script>
}

@functions {
    static object? GetFieldValue(InventoryItem item, string key) => key switch
    {
        "Text1" => item.Text1,
        "Text2" => item.Text2,
        "Text3" => item.Text3,
        "Number1" => item.Number1,
        "Number2" => item.Number2,
        "Number3" => item.Number3,
        _ => null
    };

    static string FormatFieldValue(object? value) => value switch
    {
        null => "-",
        string text when string.IsNullOrWhiteSpace(text) => "-",
        decimal number => number.ToString("0.##"),
        _ => value.ToString() ?? "-"
    };

    static string GetStatusBadgeClass(InventoryField field, object? value)
    {
        if (!IsStatusField(field))
        {
            return string.Empty;
        }

        var status = value?.ToString()?.Trim();

        return status switch
        {
            "Available" => "status-available",
            "In use" => "status-in-use",
            "Broken" => "status-broken",
            _ => "status-unknown"
        };
    }

    static bool IsStatusField(InventoryField field) =>
        string.Equals(field.Title?.Trim(), "Status", StringComparison.OrdinalIgnoreCase);

    static string TrimDuplicateHeading(string title, string? markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
        {
            return string.Empty;
        }

        var lines = markdown.Replace("\r\n", "\n").Split('\n').ToList();
        if (lines.Count == 0)
        {
            return markdown;
        }

        var firstContentIndex = lines.FindIndex(line => !string.IsNullOrWhiteSpace(line));
        if (firstContentIndex < 0)
        {
            return markdown;
        }

        var firstLine = lines[firstContentIndex].Trim();
        var normalizedFirstLine = firstLine.TrimStart('#', ' ').Trim();

        if (!string.Equals(normalizedFirstLine, title?.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return markdown;
        }

        lines.RemoveAt(firstContentIndex);
        while (firstContentIndex < lines.Count && string.IsNullOrWhiteSpace(lines[firstContentIndex]))
        {
            lines.RemoveAt(firstContentIndex);
        }

        return string.Join('\n', lines);
    }
}
