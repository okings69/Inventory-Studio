@model IReadOnlyList<SearchResultItem>
@inject IUiTextService T
@{
    ViewData["Title"] = T["Search"];
}
<h1 class="h3 mb-3">@T["SearchResultsFor"] "@ViewBag.Query"</h1>
@if (Model.Count == 0)
{
    <p class="text-body-secondary">@T["NoSearchResults"]</p>
}
else
{
    <div class="list-group">
        @foreach (var result in Model)
        {
            <a class="list-group-item list-group-item-action" href="@result.Url">
                <div class="d-flex justify-content-between"><strong>@result.Title</strong><span class="badge text-bg-secondary">@result.Type</span></div>
                <div class="small text-body-secondary">@result.Snippet</div>
            </a>
        }
    </div>
}
