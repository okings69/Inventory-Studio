@model ErrorViewModel
@inject IUiTextService T
@{
    ViewData["Title"] = T["ErrorTitle"];
}

<section class="state-page">
    <div class="state-panel">
        <span class="state-code">500</span>
        <h1>@T["ErrorTitle"]</h1>
        <p>@T["ErrorText"]</p>

        @if (Model.ShowRequestId)
        {
            <p class="state-request-id">
                <strong>@T["RequestId"]:</strong> <code>@Model.RequestId</code>
            </p>
        }
    </div>
</section>
